# Copy this file to .env and fill in your keys
# cp .env.example .env

# Google Gemini API Key — used for embeddings only
GEMINI_API_KEY=
# Groq API Key — used for chat LLM — https://console.groq.com/keys
GROQ_API_KEY=
# Qdrant (local Docker — default)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_documents_v2

# Qdrant Cloud (optional — leave blank to use local)
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your_qdrant_cloud_api_key

# Models
EMBEDDING_MODEL=models/gemini-embedding-001
# Chunking
MAX_CONTEXT_CHARS=10000
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True

# Cloudinary
CLOUDINARY_CLOUD_NAME=dfo52luqb
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Image extraction
EXTRACT_PDF_IMAGES=true
